pipeline {
    agent any

    stages {
        stage('Get Code') {
            steps {
                 // 1. Descargo el código fuente exclusivamente desde la rama develop
                checkout([$class: 'GitSCM', 
                    branches: [[name: '*/develop']], 
                    extensions: [], 
                    userRemoteConfigs: [[url: 'https://github.com/santt3131/devops_caso1.4_aws.git']]
                ])
            }
        }

    stage('Static Test') {
        steps {
            echo 'Iniciando Análisis Estático en AWS EC2 (Ubuntu)...'

            // Lanzamos Flake8 mediante el intérprete de Python 3 para analizar el estilo del código,
            // formateando la salida como PyLint y guardándola en el archivo 'flake8.out'.
            // El parámetro '--exit-zero' evita que la etapa falle si se encuentran advertencias.
            sh '''
                flake8 --format=pylint --exit-zero src > flake8.out
            '''

            // Ejecutamos Bandit de forma recursiva en 'src' para detectar fallos de seguridad,
            // guardando los hallazgos en 'bandit.out'
            // Usa '--exit-zero' para reportar éxito al sistema y asegurar que el pipeline continúe.
            sh '''
                bandit --exit-zero -r src -f custom -o bandit.out --msg-template "{abspath}:{line}: [{test_id}] {msg}"
            '''

            
            // Publicamos el informe de Flake8 en Jenkins usando reglas de calidad (Quality Gates)
            // Si se encuentran 8 o más advertencias en total, la etapa pasará a estado inestable (amarillo)
            // Si los fallos de estilo alcanzan los 10 o más, se marcará como fallido (rojo)
            recordIssues tools: [flake8(name: 'Flake8', pattern: 'flake8.out')],
                qualityGates: [
                    [threshold: 8, type: 'TOTAL', unstable: true], 
                    [threshold: 10, type: 'TOTAL', unstable: false]
                ]
    
            // Procesamos el archivo 'bandit.out' con el parser de PyLint para publicar el reporte de seguridad
            // Si el análisis detecta 2 o más vulnerabilidades totales, la etapa pasa a estado inestable (amarillo)
            // Si se encuentran 4 o más fallos de seguridad,  se marcará como fallido (rojo)
            recordIssues tools: [pyLint(name: 'Bandit', pattern: 'bandit.out')],
                qualityGates: [
                    [threshold: 2, type: 'TOTAL', unstable: true], 
                    [threshold: 4, type: 'TOTAL', unstable: false]
                ]
        }
    }

    stage('Deploy') {
        steps {
            echo 'Iniciando el proceso de Despliegue en Staging con AWS SAM...'

            // Ejecución secuencial de comandos SAM automatizados y sin confirmaciones manuales
            sh '''
                # 1. Construimos las funciones Lambda y gestiona sus dependencias de forma aislada
                sam build

                # 2. Validamos la estructura y sintaxis de la plantilla template.yaml en la región especificada
                sam validate --region us-east-1

                # 3.Desplegamos en AWS usando la configuración de Staging del archivo samconfig.toml
                # --resolve-s3: Crea automáticamente el bucket de S3
                # --no-confirm-changeset: Quita la pregunta manual de confirmación para que Jenkins corra solo
                # --no-fail-on-empty-changeset: Si ejecutas el pipeline dos veces seguidas sin cambiar código 
                # o infraestructura, evita que AWS lance un error por "no haber cambios".
                sam deploy --config-env staging --resolve-s3 --no-confirm-changeset --no-fail-on-empty-changeset
            '''
        }
    }

    stage('Rest Test') {
        steps {
            echo 'Iniciando Pruebas de Integración con Pytest en Staging...'

            // Ejecutamos los comandos necesarios para preparar el entorno y lanzar los tests
            sh '''

                # 1. Capturamos dinámicamente la URL del API Gateway usando tu comando de CloudFormation
                # Guardamos el resultado en una variable de Bash llamada API_URL
                API_URL=$(aws cloudformation describe-stacks \
                    --stack-name todo-list-aws-staging \
                    --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" \
                    --region us-east-1 \
                    --output text)

                # Mostramos la URL en el log de Jenkins para verificar que se capturó correctamente
                echo "La URL de la API detectada es: ${API_URL}"

                # 2. Lanzamos Pytest pasando la URL capturada como variable de entorno (BASE_URL)
                # Apuntamos directamente a la ruta del archivo provisto en el caso práctico
                BASE_URL=${API_URL} python3 -m pytest test/integration/todoApiTest.py -v
            '''
        }
    }

    stage('Promote') {
            steps {
                echo 'Subiendo el código a Producción (Merge develop -> master con protección de Jenkinsfile)...'
                
                withCredentials([usernamePassword(credentialsId: 'github-token', 
                                                 passwordVariable: 'GIT_PASSWORD', 
                                                 usernameVariable: 'GIT_USERNAME')]) {
                    script {
                        def jenkinsfileMasterOriginal = ""

                        // Jenkins crea y se sitúa en una carpeta temporal aislada en el disco
                        dir('temporal_master_respaldo') {
                            git branch: 'master', url: 'https://github.com/santt3131/devops_caso1.4_aws.git'
                            
                            // Jenkins lee el Jenkinsfile original de producción mediante su función nativa
                            jenkinsfileMasterOriginal = readFile 'JENKINSFILE'
                        }
                        
                        // Al salir del bloque dir(), Jenkins nos regresa automáticamente 
                        // al espacio de trabajo original donde está la rama 'develop'

                        // 1. FUSIÓN DEL CÓDIGO FUENTE EN LINUX
                        sh '''
                            git config user.email "jenkins_demo_aws@gmail.com"
                            git config user.name "Jenkins CI"
                            git fetch origin
                            
                            git checkout master
                            git reset --hard origin/master
                            # Fusiona develop, pero si hay conflicto, gana master automáticamente
                            git merge origin/develop -X ours --no-edit
                        '''

                        // 2. RESTAURACIÓN DEL ARCHIVO DESDE JENKINS
                        // Machacamos el archivo modificado con el texto original que salvamos en la variable
                        writeFile file: 'JENKINSFILE', text: jenkinsfileMasterOriginal

                        // 3. ENVÍO FINAL SEGURO A GITHUB
                        sh """
                            git add JENKINSFILE
                            
                            # Si la fusión modificó el archivo, creamos un nuevo commit normal.
                            # El "|| true" evita que el pipeline falle si no hubo cambios reales que commitear.
                            git commit -m "Jenkins: Restaurando Jenkinsfile original de master" || true
                            
                            # Inyección segura de credenciales para el push
                            GIT_URL=\$(git remote get-url origin | sed "s/https:\\/\\//https:\\/\\/${GIT_USERNAME}:${GIT_PASSWORD}@/")
                            
                            # Push estándar sin banderas de fuerza
                            git push "\${GIT_URL}" master
                        """
                        
                        echo "¡Promoción exitosa! Jenkins ha garantizado que predomine el Jenkinsfile de master."
                    }
                }
            }
    }
    
    }

    post {
        always {
            echo 'Limpiando el espacio de trabajo (Workspace)...'
            cleanWs()
        }
    }
}